  aboutText: "\u042D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u044F-0: \u0421\u0442\u0430\u043D\u0446\u0438\u044F
    \u041F\u0443\u043B\u044C\u0441\u0430\u0440\n\u041A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0438\u043C\u0443\u043B\u044F\u0442\u043E\u0440 \u0432 \u044D\u0441\u0442\u0435\u0442\u0438\u043A\u0435
    sovietwave,\n\u043E\u0431\u0443\u0447\u0430\u044E\u0449\u0438\u0439 \u043E\u0441\u043D\u043E\u0432\u0430\u043C
    \u0442\u0440\u043E\u0438\u0447\u043D\u043E\u0439 \u043B\u043E\u0433\u0438\u043A\u0438\n\n\u0410\u0432\u0442\u043E\u0440
    \u0438\u0434\u0435\u0438, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A,
    \u0434\u0438\u0437\u0430\u0439\u043D\u0435\u0440:\n\u0427\u0430\u0439\u043A\u0438\u043D
    \u0412\u0430\u0434\u0438\u043C\n\n\u0412\u0435\u0440\u0441\u0438\u044F \u0438\u0433\u0440\u044B:
