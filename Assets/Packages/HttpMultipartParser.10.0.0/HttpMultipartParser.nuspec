<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>HttpMultipartParser</id>
    <version>10.0.0</version>
    <authors>Jake Woods, Jeremie Desautels</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/Http-Multipart-Data-Parser/Http-Multipart-Data-Parser</projectUrl>
    <description>A C# Http Multipart/form-data parser that works correctly on binary data and very large files.</description>
    <releaseNotes>https://github.com/Http-Multipart-Data-Parser/HttpMultipartParser/releases/tag/10.0.0</releaseNotes>
    <copyright>Copyright © Jake Woods and contributors 2013 - Present</copyright>
    <tags>http multipart parser form data</tags>
    <repository type="git" url="https://github.com/Http-Multipart-Data-Parser/HttpMultipartParser.git" branch="refs/heads/main" commit="cb182451c8aa6b498e892cedb217eec8367e21ad" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.IO.RecyclableMemoryStream" version="3.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Buffers" version="4.6.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.CSharp" version="4.7.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.IO.RecyclableMemoryStream" version="3.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Buffers" version="4.6.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>